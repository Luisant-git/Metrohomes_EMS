// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int      @id @default(autoincrement())
  employeeCode          String   @unique    
  name                  String
  email                 String   @unique
  mobile                String   @unique
  pin                   String               // 4-digit PIN (hashed)
  pinExpiresAt          DateTime?
  pinAttempts           Int      @default(0)
  role                  String               // Admin, Director, Regional Manager, etc.
  status                String   @default("Active")
  
  // Personal Information
  avatar                String?
  fatherHusbandName     String?
  address               String?
  dob                   DateTime?
  
  // Nominee Information
  nomineeName           String?
  nomineeRelationship   String?
  
  // Bank Information
  bankName              String?
  bankAccountNo         String?
  ifscCode              String?
  bankBranch            String?
  panNo                 String?
  
  // Hierarchy (Self-referencing)
  parentUserId          Int?
  parent                User?    @relation("UserHierarchy", fields: [parentUserId], references: [id])
  children              User[]   @relation("UserHierarchy")
  
  createdBy             Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  customers             Customer[]

  @@map("users")
}

model Site {
  id              Int      @id @default(autoincrement())
  name            String
  location        String
  totalPlots      Int?  
  availablePlots  Int?
  pricePerSqft    Float?   
  description     String?
  images          Json?                             // Array of image URLs
  brochure        String?                           // Brochure file URL
  documents       Json?                             // Array of document URLs
  createdBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("Active")       // Active, Inactive
  customers       Customer[]

  @@map("sites")
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?  @unique
  phone       String   @unique
  address     String?
  visitDate   DateTime?
  visitTime   String?
  persons     Int?
  location    String?
  notes       String?
  occupation   String? 
  siteId      Int?    
  site        Site?   @relation(fields: [siteId], references: [id])
  purchaseMode String?
  createdBy   Int?
  user        User?   @relation(fields: [createdBy], references: [id])

  status String?
  driverName String?
  driverMobile String?
  cabNumber String?
  pinCode String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
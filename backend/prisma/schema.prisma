// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int      @id @default(autoincrement())
  employeeCode          String   @unique    
  name                  String
  email                 String   @unique
  mobile                String   @unique
  pin                   String               // 4-digit PIN (hashed)
  pinExpiresAt          DateTime?
  pinAttempts           Int      @default(0)
  role                  String               // Admin, Director, Regional Manager, etc.
  status                String   @default("Active")
  
  // Personal Information
  avatar                String?
  fatherHusbandName     String?
  address               String?
  dob                   DateTime?
  
  // Nominee Information
  nomineeName           String?
  nomineeRelationship   String?
  
  // Bank Information
  bankName              String?
  bankAccountNo         String?
  ifscCode              String?
  bankBranch            String?
  panNo                 String?
  
  // Hierarchy (Self-referencing)
  parentUserId          Int?
  parent                User?    @relation("UserHierarchy", fields: [parentUserId], references: [id])
  children              User[]   @relation("UserHierarchy")
  
  createdBy             Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  customers             Customer[]
  assignedVisits        SiteVisit[] @relation("AssignedUser")

  @@map("users")
}

model Site {
  id              Int @id @default(autoincrement())

  name            String
  location        String
  totalPlots      Int?
  availablePlots  Int?
  pricePerSqft    Float?
  description     String?

  images          Json?
  brochure        String?
  documents       Json?

  createdBy       Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  status          String @default("Active")

  visits          SiteVisit[]

  @@map("sites")
}

model Customer {
  id          Int      @id @default(autoincrement())

  name        String
  email       String?  @unique
  phone       String   @unique
  address     String?
  pinCode     String?
  occupation  String?

  createdBy   Int?
  user        User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  visits      SiteVisit[]

  // OTP fields for mobile verification
  otp                   String?
  otpExpiresAt          DateTime?
  otpAttempts           Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("customers")
}

model SiteVisit {
  id Int @id @default(autoincrement())

  customerId Int
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  siteId Int
  site Site @relation(fields: [siteId], references: [id], onDelete: Restrict)

  visitDate DateTime?
  visitTime String?

  persons Int?

  pickupLocation String?

  purchaseMode String?

  notes String?

  status String @default("Interested")

  assignedTo Int?
  assignedToUser User? @relation("AssignedUser", fields: [assignedTo], references: [id], onDelete: SetNull)

  driverName String?
  driverMobile String?
  cabNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_visits")
}